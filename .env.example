# Configurações do BimblongDJ
# Renomeie este arquivo para .env e preencha com suas credenciais.

# Token do seu bot do Discord (Obtido em: https://discord.com/developers/applications)
DISCORD_TOKEN=seu_token_aqui

# Chave de API do Google Gemini (Obtido em: https://aistudio.google.com/)
GEMINI_API_KEY=sua_chave_do_gemini_aqui

# Credenciais do Spotify (Obtido em: https://developer.spotify.com/dashboard)
SPOTIFY_CLIENT_ID=seu_client_id_aqui
SPOTIFY_CLIENT_SECRET=seu_client_secret_aqui
